<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>หน้าหลัก | Admin</title>
  <link rel="stylesheet" href="/admincscit/assets/vendor/fonts/boxicons.css">
  <link rel="stylesheet" href="/admincscit/assets/vendor/css/core.css">
  <link rel="stylesheet" href="/admincscit/assets/vendor/css/theme-default.css">
  <link href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/node_modules/sweetalert2/dist/sweetalert2.min.css">
  <link rel="stylesheet" href="/node_modules/waitme/waitMe.min.css">
  <link rel="stylesheet" href="/node_modules/datatables.net-bs5/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="/assets/css/select2.min.css">
  <style>
    body {
      font-family: 'Bai Jamjuree', sans-serif !important;
    }

    .layout-container {
      background-color: #669bbc !important;
    }

    .table>thead {
      background-color: #e0dbf7;
    }

    .swal2-container {
      z-index: 20000 !important;
    }

    #modalCircular .modal-dialog {
      max-width: 900px;
    }

    .badge-status-on {
      background: #099a49;
    }

    .badge-status-off {
      background: #de0508;
    }

    /* Select2 inside Bootstrap modal */
    .select2-container {
      z-index: 99999 !important;
    }

    .select2-dropdown {
      z-index: 99999 !important;
    }
  </style>
</head>

<body>
  <div class="layout-wrapper layout-content-navbar">
    <div class="layout-container">

      <!-- Sidebar -->
      <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
        <div class="app-brand demo pt-4 pb-3" style="height: auto;">
          <a href="/admin/dashboard" class="app-brand-link">
            <span class="app-brand-text demo menu-text fw-bolder ms-2 text-uppercase"
              style="color:#00296b; font-size: 24px;">
              Circular<span style="color:#168aad; font-size: 28px;"> BKK</span>
            </span>
          </a>
          <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none mt-3">
            <i class="bx bx-chevron-left bx-sm align-middle"></i>
          </a>
        </div>
        <div class="menu-inner-shadow"></div>
        <ul class="menu-inner py-1">
          <li class="menu-item">
            <a href="/admin/dashboard" class="menu-link">
              <i class="menu-icon tf-icons bx bx-home-circle"></i>
              <div style="font-size:18px;font-weight:700;">หน้าหลัก</div>
            </a>
          </li>
          <li class="menu-header small text-uppercase"><span class="menu-header-text" style="font-size:18px;">Pages
              Menu</span></li>

          <% if (ad_permiss==='superadmin' ) { %>
            <!-- ข้อมูลหลัก -->
            <li class="menu-item">
              <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon tf-icons bx bx-data"></i>
                <div style="font-size:18px;font-weight:700;">ข้อมูลหลัก</div>
              </a>
              <ul class="menu-sub">
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-year')" class="menu-link">
                    <div style="font-size:17px;">ปี พ.ศ.</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-results')" class="menu-link">
                    <div style="font-size:17px;">ผลการพิจารณา</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-agency')" class="menu-link">
                    <div style="font-size:17px;">ผู้รับผิดชอบ</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-categories')" class="menu-link">
                    <div style="font-size:17px;">หมวดหมู่</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-mkk')" class="menu-link">
                    <div style="font-size:17px;">มติ ก.ก.</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-mw')" class="menu-link">
                    <div style="font-size:17px;">มติคณะทำงาน</div>
                  </a>
                </li>
                <li class="menu-item">
                  <a href="javascript:void(0);" onclick="showSection('sec-master-status')" class="menu-link">
                    <div style="font-size:17px;">สถานะการใช้งาน</div>
                  </a>
                </li>
              </ul>
            </li>

            <!-- จัดการหนังสือเวียน -->
            <li class="menu-item">
              <a href="javascript:void(0);" onclick="showSection('sec-circular')" class="menu-link">
                <i class="menu-icon tf-icons bx bx-book-content"></i>
                <div style="font-size:18px;font-weight:700;">จัดการหนังสือเวียน</div>
              </a>
            </li>

            <!-- รายงาน -->
            <li class="menu-item">
              <a href="javascript:void(0);" onclick="showSection('sec-report')" class="menu-link">
                <i class="menu-icon tf-icons bx bx-bar-chart-alt-2"></i>
                <div style="font-size:18px;font-weight:700;">รายงาน</div>
              </a>
            </li>
            <% } %>

              <!-- การตั้งค่าระบบ -->
              <li class="menu-item open">
                <a href="javascript:void(0);" class="menu-link menu-toggle">
                  <i class="menu-icon tf-icons bx bx-dock-top"></i>
                  <div style="font-size:18px;font-weight:700;">การตั้งค่าระบบ</div>
                </a>
                <ul class="menu-sub">
                  <li class="menu-item">
                    <a href="javascript:void(0);" onclick="openProfileModal()" class="menu-link">
                      <div style="font-size:18px;">โปรไฟล์ของฉัน</div>
                    </a>
                  </li>
                  <li class="menu-item">
                    <a href="javascript:void(0);" onclick="openPasswordModal()" class="menu-link">
                      <div style="font-size:18px;">เปลี่ยนรหัสผ่าน</div>
                    </a>
                  </li>
                  <li class="menu-item">
                    <a href="#" class="menu-link text-danger" onclick="doLogout()">
                      <div style="font-size:18px;">ออกจากระบบ</div>
                    </a>
                  </li>
                </ul>
              </li>
        </ul>
      </aside>

      <!-- Main -->
      <div class="layout-page">
        <!-- Navbar -->
        <nav
          class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme">
          <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
            <a class="nav-item nav-link px-0 me-xl-4" href="javascript:void(0)">
              <i class="bx bx-menu bx-sm"></i>
            </a>
          </div>
          <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
            <ul class="navbar-nav flex-row align-items-center ms-auto">
              <li class="nav-item me-3 d-flex align-items-center">
                <span class="text-secondary fw-bold" style="font-size: 1.1em;"><strong
                    class="text-primary user-name-display">
                    <%= ad_name %>
                  </strong></span>
              </li>
              <li class="nav-item navbar-dropdown dropdown-user dropdown">
                <a class="nav-link dropdown-toggle hide-arrow" href="javascript:void(0);" data-bs-toggle="dropdown">
                  <div class="avatar avatar-online">
                    <img src="/admincscit/assets/img/uploads/avatar.jpg" alt class="w-px-40 h-auto rounded-circle">
                  </div>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <a class="dropdown-item" href="#">
                      <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                          <div class="avatar avatar-online">
                            <img src="/admincscit/assets/img/uploads/avatar.jpg" alt
                              class="w-px-40 h-auto rounded-circle">
                          </div>
                        </div>

                        <div class="flex-grow-1">
                          <span class="fw-semibold d-block user-name-display">
                            <%= ad_name %>
                          </span>
                          <small class="text-muted d-block">
                            <%= ad_permiss==='superadmin' ? 'SuperAdmin' : 'Admin' %>
                          </small>
                        </div>

                      </div>
                    </a>
                  </li>
                  <li>
                    <div class="dropdown-divider"></div>
                  </li>
                  <li>
                    <a class="dropdown-item" href="javascript:void(0);" onclick="openProfileModal()">
                      <i class="bx bx-user me-2"></i><span>โปรไฟล์ของฉัน</span>
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="javascript:void(0);" onclick="openPasswordModal()">
                      <i class="bx bx-key me-2"></i><span>เปลี่ยนรหัสผ่าน</span>
                    </a>
                  </li>
                  <li>
                    <div class="dropdown-divider"></div>
                  </li>
                  <li><a class="dropdown-item" href="#" onclick="doLogout()"><i
                        class="bx bx-power-off me-2"></i><span>ออกจากระบบ</span></a></li>
                </ul>
              </li>
            </ul>
          </div>
        </nav>

        <!-- Content -->
        <div class="content-wrapper">
          <div class="container-xxl flex-grow-1 container-p-y">

            <!-- Stats Cards Row 1 -->
            <div class="row mb-2" id="stats-row">
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult('all')" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-file fs-3 me-2 text-info"></i>
                      <span class="fw-semibold">หนังสือเวียนที่มีในระบบ</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-info"><span id="count-all">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(2)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-check-circle fs-3 me-2 text-success"></i>
                      <span class="fw-semibold">หนังสือเวียนที่นำมาใช้</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-success"><span id="count-use">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(4)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-edit fs-3 me-2 text-warning"></i>
                      <span class="fw-semibold">นำมาปรับใช้</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-warning"><span id="count-adjust">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(5)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-x-circle fs-3 me-2 text-danger"></i>
                      <span class="fw-semibold">ไม่ใช้</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-danger"><span id="count-notuse">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
            </div>

            <!-- Stats Cards Row 2 -->
            <div class="row mb-4">
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(12)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-time-five fs-3 me-2" style="color: #f67d3c;"></i>
                      <span class="fw-semibold">รอพิจารณาผล</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold" style="color: #f67d3c;"><span id="count-pending">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(11)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-error-circle fs-3 me-2 text-secondary"></i>
                      <span class="fw-semibold">ตกหล่น</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-secondary"><span id="count-missing">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
              <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card bg-dark text-white h-100 cursor-pointer" onclick="filterByResult(1)" style="cursor: pointer;">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bx bx-help-circle fs-3 me-2 text-light"></i>
                      <span class="fw-semibold">ไม่ระบุ</span>
                    </div>
                    <h3 class="card-title mb-0 fw-bold text-light"><span id="count-none">...</span> <small
                        class="fs-6">เรื่อง</small></h3>
                  </div>
                </div>
              </div>
            </div>


            <!-- ===== SECTION: หนังสือเวียน (หน้าหลัก) ===== -->
            <div id="sec-circular">
              <!-- Table -->
              <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                  <h5 class="mb-0">รายการหนังสือเวียน</h5>
                  <% if (ad_permiss==='superadmin' ) { %>
                    <button class="btn btn-primary btn-sm" id="btn-add"><i
                        class="bx bx-plus me-1"></i>เพิ่มหนังสือเวียน</button>
                    <% } %>
                </div>
                <div class="card-body" id="table-wrap">
                  <table id="table_index" class="table table-bordered table-striped" style="width:100%">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>ปี พ.ศ.</th>
                        <th>เลขที่หนังสือ</th>
                        <th>เรื่อง</th>
                        <th>ผลการพิจารณา</th>
                        <th>สถานะ</th>
                        <th>จัดการ</th>
                      </tr>
                    </thead>
                    <tbody id="tbody-main"></tbody>
                  </table>
                </div>
              </div>
            </div><!-- /sec-circular -->

            <!-- ===== SECTION: ข้อมูลหลัก ===== -->
            <% ['year','results','agency','categories','mkk','mw','status'].forEach(function(t){ %>
              <div id="sec-master-<%= t %>" style="display:none;">
                <div class="card">
                  <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0" id="master-title-<%= t %>">ข้อมูลหลัก</h5>
                    <button class="btn btn-success btn-sm" onclick="openMasterModal('<%= t %>')">
                      <i class="bx bx-plus me-1"></i>เพิ่มข้อมูล
                    </button>
                  </div>
                  <div class="card-body">
                    <table id="table-master-<%= t %>" class="table table-bordered table-striped" style="width:100%">
                      <thead id="master-thead-<%= t %>"></thead>
                      <tbody id="master-tbody-<%= t %>"></tbody>
                    </table>
                  </div>
                </div>
              </div>
              <% }); %>

                <!-- ===== SECTION: รายงาน ===== -->
                <div id="sec-report" style="display:none;">
                  <div class="row mb-3">
                    <div class="col-12">
                      <div class="card">
                        <div class="card-header">
                          <h5 class="mb-0"><i class="bx bx-bar-chart-alt-2 me-2"></i>รายงานสรุปหนังสือเวียน</h5>
                        </div>
                        <div class="card-body">
                          <div class="row mb-3 g-2 align-items-end">
                            <div class="col-md-3">
                              <label class="form-label fw-bold">ปี พ.ศ.</label>
                              <select id="rpt-year" class="form-select">
                                <option value="">ทั้งหมด</option>
                              </select>
                            </div>
                            <div class="col-md-3">
                              <label class="form-label fw-bold">ผลการพิจารณา</label>
                              <select id="rpt-results" class="form-select">
                                <option value="">ทั้งหมด</option>
                              </select>
                            </div>
                            <div class="col-md-3">
                              <label class="form-label fw-bold">ผู้รับผิดชอบ</label>
                              <select id="rpt-agency" class="form-select">
                                <option value="">ทั้งหมด</option>
                              </select>
                            </div>
                            <div class="col-md-3">
                              <button class="btn btn-primary w-100" onclick="loadReport()">
                                <i class="bx bx-search me-1"></i>ออกรายงาน
                              </button>
                            </div>
                          </div>
                          <!-- Summary Cards -->
                          <div class="row mb-3" id="rpt-summary-row" style="display:none;">
                            <div class="col-md-3">
                              <div class="card bg-info text-white text-center py-3">
                                <h4 id="rpt-cnt-all">0</h4><small>ทั้งหมด</small>
                              </div>
                            </div>
                            <div class="col-md-3">
                              <div class="card bg-success text-white text-center py-3">
                                <h4 id="rpt-cnt-use">0</h4><small>นำมาใช้</small>
                              </div>
                            </div>
                            <div class="col-md-3">
                              <div class="card bg-warning text-white text-center py-3">
                                <h4 id="rpt-cnt-adjust">0</h4><small>นำมาปรับใช้</small>
                              </div>
                            </div>
                            <div class="col-md-3">
                              <div class="card bg-danger text-white text-center py-3">
                                <h4 id="rpt-cnt-notuse">0</h4><small>ไม่ใช้</small>
                              </div>
                            </div>
                          </div>
                          <!-- Report Table -->
                          <table id="table-report" class="table table-bordered table-striped"
                            style="width:100%;display:none;">
                            <thead>
                              <tr>
                                <th>#</th>
                                <th>ปี</th>
                                <th>เลขที่หนังสือ</th>
                                <th>เรื่อง</th>
                                <th>ผลการพิจารณา</th>
                                <th>ผู้รับผิดชอบ</th>
                                <th>สถานะ</th>
                              </tr>
                            </thead>
                            <tbody id="rpt-tbody"></tbody>
                          </table>
                        </div>
                      </div>
                    </div>
                  </div>
                </div><!-- /sec-report -->

          </div>


          <!-- Footer -->
        </div>
      </div>
      <div class="content-backdrop fade"></div>
    </div>
  </div>
  </div>
  <div class="layout-overlay layout-menu-toggle"></div>
  </div>



  <!-- Modal Add/Edit -->
  <div class="modal fade" id="modalCircular" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalTitle">เพิ่มหนังสือเวียน</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="formCircular" enctype="multipart/form-data">
            <input type="hidden" name="submit_create_circular_hidden" value="1">
            <input type="hidden" name="in_id" id="field_in_id">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">เลขที่หนังสือ/ลงวันที่ <span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="in_num_date" id="field_in_num_date" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">ปี พ.ศ. <span class="text-danger">*</span></label>
                <select class="form-select" name="in_year_id" id="field_in_year_id" required></select>
              </div>
              <div class="col-12">
                <label class="form-label">ชื่อเรื่อง <span class="text-danger">*</span></label>
                <textarea class="form-control" name="in_detail" id="field_in_detail" rows="2" required></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">รายละเอียดเพิ่มเติม</label>
                <textarea class="form-control" name="in_detail_ag" id="field_in_detail_ag" rows="2"></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label">มติ ก.ก.</label>
                <select class="form-select" name="in_mkk_id" id="field_in_mkk_id"></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">มติคณะทำงาน</label>
                <select class="form-select" name="in_mw_id" id="field_in_mw_id"></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">ผลการพิจารณา <span class="text-danger">*</span></label>
                <select class="form-select" name="in_results_id" id="field_in_results_id" required></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">สถานะ <span class="text-danger">*</span></label>
                <select class="form-select" name="in_status_id" id="field_in_status_id" required></select>
              </div>
              <div class="col-12">
                <label class="form-label">ผู้รับผิดชอบ <span class="text-danger">*</span></label>
                <select class="form-select" name="ag_id[]" id="field_ag_id" multiple required
                  style="width:100%"></select>
              </div>
              <div class="col-12">
                <label class="form-label">หมวดหมู่ <span class="text-danger">*</span></label>
                <select class="form-select" name="cat_id[]" id="field_cat_id" multiple required
                  style="width:100%"></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Link เว็บไซต์</label>
                <input type="text" class="form-control" name="in_link" id="field_in_link" placeholder="https://...">
                <input type="hidden" name="lkk_none" value="-">
              </div>
              <div class="col-md-6">
                <label class="form-label">หมายเหตุ</label>
                <input type="text" class="form-control" name="in_etc" id="field_in_etc">
              </div>
              <div class="col-12">
                <label class="form-label">ไฟล์มติ ก.ก. (PDF)</label>
                <input type="file" class="form-control" name="mkk_ref_upload_in" id="field_mkk_file" accept=".pdf">
                <input type="hidden" name="mkk_ref_link_in" value="">
                <input type="hidden" name="mkk_ref_none_in" value="-">
                <input type="hidden" name="existing_file_in" id="field_existing_file">
                <small class="text-muted" id="existing_file_label"></small>
              </div>
              <div class="col-12">
                <label class="form-label">อ้างอิงหนังสือเวียน</label>
                <select class="form-select" name="in_id_ref[]" id="field_ref" multiple style="width:100%"></select>
                <input type="hidden" name="ref_none" id="field_ref_none" value="-">
              </div>
