        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="button" class="btn btn-primary" onclick="savePassword()">บันทึก</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="/admincscit/assets/vendor/libs/jquery/jquery.js"></script>
  <script src="/admincscit/assets/vendor/libs/popper/popper.js"></script>
  <script src="/admincscit/assets/vendor/js/bootstrap.js"></script>
  <script src="/admincscit/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
  <script src="/admincscit/assets/vendor/js/menu.js"></script>
  <script src="/admincscit/assets/js/main.js"></script>
  <script src="/node_modules/sweetalert2/dist/sweetalert2.min.js"></script>
  <script src="/node_modules/waitme/waitMe.min.js"></script>
  <script src="/node_modules/datatables.net/js/jquery.dataTables.min.js"></script>
  <script src="/node_modules/datatables.net-bs5/js/dataTables.bootstrap5.min.js"></script>
  <script src="/assets/js/moment.min.js"></script>
  <script src="/assets/js/moment-with-locales.min.js"></script>
  <script src="/assets/js/select2.min.js"></script>
  <link rel="stylesheet" href="/assets/css/select2.min.css">

  <script>
    const JWT_SECRET_CLIENT = null; // decode on server-side only
    let tableInstance = null;
    let allData = {};
    let editMode = false;

    function parseJwt(token) {
      try {
        const base64 = token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
        // atob() คืน binary string, ต้องแปลงเป็น UTF-8 ก่อน JSON.parse
        const jsonPayload = decodeURIComponent(
          atob(base64).split('').map(c =>
            '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)
          ).join('')
        );
        return JSON.parse(jsonPayload);
      } catch (e) { return null; }
    }

    function doLogout() {
      Swal.fire({ title: 'ออกจากระบบ?', icon: 'warning', showCancelButton: true, confirmButtonText: 'ออกจากระบบ', cancelButtonText: 'ยกเลิก' })
        .then(r => { if (r.isConfirmed) { $.post('/admin/logout', () => location.href = '/admin/login'); } });
    }

    $.get('/admincscit/service/dashboard/index.php', function (r) {
      if (!r.status) return;
      const d = r.response;
      $('#count-all').text(d.count_all || 0);
      $('#count-use').text(d.count_use || 0);
      $('#count-adjust').text(d.count_adjust || 0);
      $('#count-notuse').text(d.count_notuse || 0);
      $('#count-pending').text(d.count_pending || 0);
      $('#count-missing').text(d.count_missing || 0);
      $('#count-none').text(d.count_none || 0);
    });

    function filterByResult(resultId) {
      if (!allData.information) return;
      
      // เลื่อนหน้าจอไปที่ตาราง
      $('html, body').animate({
          scrollTop: $("#sec-circular").offset().top - 20
      }, 500);

      if (resultId === 'all') {
        renderTable(allData.information);
      } else {
        const filtered = allData.information.filter(item => {
          return item.results && item.results.results_id == resultId;
        });
        renderTable(filtered);
      }
    }

    // Load main data
    function loadData() {
      $('#table-wrap').waitMe({ effect: 'win8', text: 'กำลังโหลด...' });
      $.get('/admincscit/service/account/circular_add/main.php', function (r) {
        $('#table-wrap').waitMe('hide');
        if (!r.status) return Swal.fire('Error', r.message, 'error');
        const decoded = parseJwt(r.response);
        if (!decoded) return Swal.fire('Error', 'ไม่สามารถถอดรหัสข้อมูลได้', 'error');
        allData = decoded.response;
        renderTable(allData.information);
        populateDropdowns(allData);
      }).fail(function () { $('#table-wrap').waitMe('hide'); Swal.fire('Error', 'โหลดข้อมูลไม่สำเร็จ', 'error'); });
    }

    function populateDropdowns(data) {
      $('#field_in_year_id').html('<option value="">-- เลือกปี --</option>');
      data.year.forEach(y => $('#field_in_year_id').append(`<option value="${y.year_id}">${y.year_value}</option>`));

      $('#field_in_mkk_id').html('<option value="">-- ไม่ระบุ --</option>');
      data.mati_kk.forEach(m => $('#field_in_mkk_id').append(`<option value="${m.mkk_id}">${m.mkk_name}</option>`));

      $('#field_in_mw_id').html('<option value="">-- ไม่ระบุ --</option>');
      data.mati_work.forEach(m => $('#field_in_mw_id').append(`<option value="${m.mw_id}">${m.mw_name}</option>`));

      $('#field_in_results_id').html('<option value="">-- เลือกผล --</option>');
      data.results.forEach(r => $('#field_in_results_id').append(`<option value="${r.results_id}">${r.results_detail}</option>`));

      $('#field_in_status_id').html('<option value="">-- เลือกสถานะ --</option>');
      data.status.forEach(s => $('#field_in_status_id').append(`<option value="${s.status_id}">${s.status_value}</option>`));

      // Select2 สำหรับ multi-select fields
      $('#field_ag_id').html('');
      data.agency.forEach(a => $('#field_ag_id').append(`<option value="${a.ag_id}">${a.ag_name}</option>`));

      $('#field_cat_id').html('');
      data.categories.forEach(c => $('#field_cat_id').append(`<option value="${c.cat_id}">${c.cat_name}</option>`));

      $('#field_ref').html('<option value="">(ไม่มีอ้างอิง)</option>');
      if (allData.information) {
        allData.information.forEach(i => $('#field_ref').append(`<option value="${i.in_id}">${i.in_num_date} — ${i.in_detail.substring(0, 50)}</option>`));
      }

      // Re-init Select2 (ต้องทำหลังเพิ่ม options)
      $('#field_ag_id').select2({ dropdownParent: $('#modalCircular .modal-content'), placeholder: '-- เลือกผู้รับผิดชอบ --', allowClear: true, width: '100%' });
      $('#field_cat_id').select2({ dropdownParent: $('#modalCircular .modal-content'), placeholder: '-- เลือกหมวดหมู่ --', allowClear: true, width: '100%' });
      $('#field_ref').select2({ dropdownParent: $('#modalCircular .modal-content'), placeholder: '-- เลือกหนังสืออ้างอิง (ถ้ามี) --', allowClear: true, width: '100%' });
    }

    function renderTable(rows) {
      if (tableInstance) { tableInstance.destroy(); }
      const tbody = $('#tbody-main').empty();
      rows.forEach((item, idx) => {
        const yearVal = item.year ? item.year.year_value : '-';
        const statusVal = item.status_a ? item.status_a.status_value : '-';
        const resultsVal = item.results ? item.results.results_detail : '-';
        const statusBadge = statusVal === 'ใช้งาน'
          ? `<span class="badge bg-success">${statusVal}</span>`
          : `<span class="badge bg-danger">${statusVal}</span>`;
        // จัด agency names
        const agencyNames = (item.agency && item.agency.length > 0)
          ? item.agency.map(a => a.ag_name).join(', ')
          : '';
        const titleCell = agencyNames
          ? `${item.in_detail}<br><strong class="text-primary" style="font-size:0.85em;">&#128197; ${agencyNames}</strong>`
          : item.in_detail;
        tbody.append(`<tr>
      <td>${idx + 1}</td>
      <td>${yearVal}</td>
      <td>${item.in_num_date}</td>
      <td>${titleCell}</td>
      <td>${resultsVal}</td>
      <td>${statusBadge}</td>
      <td>
        <button class="btn btn-sm btn-warning me-1 btn-edit" data-id="${item.in_id}"><i class="bx bx-edit"></i></button>
        <button class="btn btn-sm btn-danger btn-del" data-id="${item.in_id}"><i class="bx bx-trash"></i></button>
      </td>
    </tr>`);
      });
      
      tableInstance = $('#table_index').DataTable({
        responsive: true,
        language: {
          search: 'ค้นหาในตาราง:',
          lengthMenu: 'แสดง _MENU_ รายการ',
          info: 'แสดง _START_ ถึง _END_ จากทั้งหมด _TOTAL_ รายการ',
          infoEmpty: 'ไม่มีข้อมูล',
          zeroRecords: 'ไม่พบข้อมูล',
          paginate: { first: 'แรก', last: 'สุดท้าย', next: 'ถัดไป', previous: 'ก่อนหน้า' }
        }
      });


      // อัปเดตตัวเลข Dashboard ตามข้อมูลที่แสดงในตาราง
      updateAdminDashboardStats(rows);

      // เมื่อมีการพิมพ์ค้นหาในตาราง
      tableInstance.on('search.dt', function() {
        const searchTerm = tableInstance.search().toLowerCase();
        if (!searchTerm) {
          updateAdminDashboardStats(rows); // rows is the data passed to renderTable
        } else {
           const filtered = rows.filter(item => {
              const text = (item.in_num_date + ' ' + item.in_detail).toLowerCase();
              return text.includes(searchTerm);
           });
           updateAdminDashboardStats(filtered);
        }
      });

    }

    function updateAdminDashboardStats(data) {
      if (!data) return;
      const counts = {
        all: data.length,
        use: data.filter(i => i.results && i.results.results_id == 2).length,
        adjust: data.filter(i => i.results && i.results.results_id == 4).length,
        notuse: data.filter(i => i.results && i.results.results_id == 5).length,
        pending: data.filter(i => i.results && i.results.results_id == 12).length,
        missing: data.filter(i => i.results && i.results.results_id == 11).length,
        none: data.filter(i => i.results && i.results.results_id == 1).length
      };

      $('#count-all').text(counts.all.toLocaleString());
      $('#count-use').text(counts.use.toLocaleString());
      $('#count-adjust').text(counts.adjust.toLocaleString());
      $('#count-notuse').text(counts.notuse.toLocaleString());
      $('#count-pending').text(counts.pending.toLocaleString());
      $('#count-missing').text(counts.missing.toLocaleString());
      $('#count-none').text(counts.none.toLocaleString());
    }

    // Add
    $('#btn-add').on('click', function () {
      editMode = false;
      $('#modalTitle').text('เพิ่มหนังสือเวียน');
      $('#formCircular')[0].reset();
      $('#field_in_id').val('');
      $('#existing_file_label').text('');
      $('#field_existing_file').val('');
      populateDropdowns(allData);
      $('#modalCircular').modal('show');
    });

    // Edit
    $(document).on('click', '.btn-edit', function () {
      const id = $(this).data('id');
      const item = allData.information.find(i => i.in_id == id);
      if (!item) return;
      editMode = true;
      $('#modalTitle').text('แก้ไขหนังสือเวียน');
      $('#formCircular')[0].reset();
      populateDropdowns(allData);
      $('#field_in_id').val(item.in_id);
      $('#field_in_num_date').val(item.in_num_date);
      $('#field_in_detail').val(item.in_detail);
      $('#field_in_detail_ag').val(item.in_detail_ag);
      $('#field_in_etc').val(item.in_etc === '-' ? '' : item.in_etc);
      $('#field_in_link').val(item.in_link === '-' ? '' : item.in_link);
      if (item.year) $('#field_in_year_id').val(item.year.year_id);
      if (item.mati_kk) $('#field_in_mkk_id').val(item.mati_kk.mkk_id);
      if (item.mati_work) $('#field_in_mw_id').val(item.mati_work.mw_id);
      if (item.results) $('#field_in_results_id').val(item.results.results_id);
      if (item.status_a) $('#field_in_status_id').val(item.status_a.status_id);
      if (item.agency) { $('#field_ag_id').val(item.agency.map(a => String(a.ag_id))).trigger('change'); }
      if (item.categories) { $('#field_cat_id').val(item.categories.map(c => String(c.cat_id))).trigger('change'); }
      if (item.references_info && item.references_info.length > 0) {
        $('#field_ref').val(item.references_info.map(r => String(r.in_id))).trigger('change');
        $('#field_ref_none').val('has_ref');
      } else {
        $('#field_ref_none').val('-');
      }
      if (item.in_file_mkk && item.in_file_mkk !== '-') {
        $('#field_existing_file').val(item.in_file_mkk);
        $('#existing_file_label').text('ไฟล์เดิม: ' + item.in_file_mkk);
      } else {
        $('#field_existing_file').val('');
        $('#existing_file_label').text('');
      }
      $('#modalCircular').modal('show');
    });

    // Save
    $('#btn-save').on('click', function () {
      const form = $('#formCircular')[0];
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const url = editMode
        ? '/admincscit/service/account/circular_add/update.php'
        : '/admincscit/service/account/circular_add/create.php';
      const fd = new FormData(form);
      // handle ref_none
      const refVals = $('#field_ref').val();
      if (!refVals || refVals.length === 0) fd.set('ref_none', '-');
      else fd.set('ref_none', 'has_ref');
      // handle link none
      if (!fd.get('in_link') || fd.get('in_link') === '') fd.set('lkk_none', '-');
      $('#btn-save').prop('disabled', true).text('กำลังบันทึก...');
      $.ajax({ url, method: 'POST', data: fd, processData: false, contentType: false })
        .done(function (r) {
          $('#btn-save').prop('disabled', false).text('บันทึก');
          if (r.status) {
            $('#modalCircular').modal('hide');
            Swal.fire({ icon: 'success', text: r.message, timer: 1500, showConfirmButton: false });
            loadData();
          } else {
            Swal.fire('ผิดพลาด', r.message, 'error');
          }
        })
        .fail(function (xhr) {
          $('#btn-save').prop('disabled', false).text('บันทึก');
          Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error');
        });
    });

    // Delete
    $(document).on('click', '.btn-del', function () {
      const raw_id = $(this).data('id');
      // encode id as PHP did: random_prefix(34chars) + base64(id) + random_suffix(51chars)
      const prefix = 'AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'; // 34 chars
      const suffix = 'AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'; // 51 chars
      const encoded = prefix + btoa(String(raw_id)) + suffix;
      Swal.fire({ title: 'ลบหนังสือเวียน?', icon: 'warning', showCancelButton: true, confirmButtonText: 'ลบ', cancelButtonText: 'ยกเลิก', confirmButtonColor: '#de0508' })
        .then(r => {
          if (!r.isConfirmed) return;
          $.post('/admincscit/service/account/circular_add/delete.php', { in_id: encoded })
            .done(function (res) {
              if (res.status) {
                Swal.fire({ icon: 'success', text: 'ลบสำเร็จ', timer: 1500, showConfirmButton: false });
                loadData();
              } else {
                Swal.fire('ผิดพลาด', res.message, 'error');
              }
            }).fail(function (xhr) { Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error'); });
        });
    });

    // ============ PROFILE MODAL ============
    function openProfileModal() {
      $.get('/admincscit/service/account/profile.php', function (r) {
        if (!r.status) return Swal.fire('Error', r.message, 'error');
        const d = r.response;
        $('#prof_name').val(d.a_name || '');
        $('#prof_username').val(d.a_username || '');
        $('#prof_permiss').val(d.a_permiss === 'superadmin' ? 'SuperAdmin' : 'Admin');
        $('#modalProfile').modal('show');
      }).fail(function (xhr) {
        if (xhr.status === 401) {
          Swal.fire('แจ้งเตือน', 'กรุณาเข้าสู่ระบบใหม่', 'warning').then(() => location.href = '/admin/login');
        } else {
          Swal.fire('Error', 'โหลดข้อมูลไม่สำเร็จ', 'error');
        }
      });
    }

    function saveProfile() {
      const a_name = $('#prof_name').val().trim();
      if (!a_name) return Swal.fire('แจ้งเตือน', 'กรุณากรอกชื่อ', 'warning');
      $('#modalProfile .btn-primary').prop('disabled', true).text('กำลังบันทึก...');
      $.post('/admincscit/service/account/profile.php', { a_name })
        .done(function (r) {
          $('#modalProfile .btn-primary').prop('disabled', false).text('บันทึก');
          if (r.status) {
            $('#modalProfile').modal('hide');
            $('.user-name-display').text(a_name);
            Swal.fire({ icon: 'success', text: 'บันทึกข้อมูลสำเร็จ', timer: 1500, showConfirmButton: false });
          } else {
            Swal.fire('ผิดพลาด', r.message, 'error');
          }
        })
        .fail(function (xhr) {
          $('#modalProfile .btn-primary').prop('disabled', false).text('บันทึก');
          if (xhr.status === 401) {
            Swal.fire('แจ้งเตือน', 'กรุณาเข้าสู่ระบบใหม่', 'warning').then(() => location.href = '/admin/login');
          } else {
            Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error');
          }
        });
    }

    // ============ PASSWORD MODAL ============
    function openPasswordModal() {
      $('#formPassword')[0].reset();
      $('#modalPassword').modal('show');
    }

    function savePassword() {
      const old_password = $('#pwd_old').val();
      const new_password = $('#pwd_new').val();
      const confirm_password = $('#pwd_confirm').val();
      if (!old_password || !new_password || !confirm_password)
        return Swal.fire('แจ้งเตือน', 'กรุณากรอกข้อมูลให้ครบ', 'warning');
      if (new_password !== confirm_password)
        return Swal.fire('แจ้งเตือน', 'รหัสผ่านใหม่ไม่ตรงกัน', 'warning');
      if (new_password.length < 6)
        return Swal.fire('แจ้งเตือน', 'รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร', 'warning');
      $('#modalPassword .btn-primary').prop('disabled', true).text('กำลังบันทึก...');
      $.post('/admincscit/service/account/repassword.php', { old_password, new_password, confirm_password })
        .done(function (r) {
          $('#modalPassword .btn-primary').prop('disabled', false).text('บันทึก');
          if (r.status) {
            $('#modalPassword').modal('hide');
            $('#formPassword')[0].reset();
            Swal.fire({ icon: 'success', text: 'เปลี่ยนรหัสผ่านสำเร็จ', timer: 1500, showConfirmButton: false });
          } else {
            Swal.fire('ผิดพลาด', r.message, 'error');
          }
        })
        .fail(function (xhr) {
          $('#modalPassword .btn-primary').prop('disabled', false).text('บันทึก');
          Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error');
        });
    }

    // ============ SECTION TOGGLE ============
    function showSection(secId) {
      // Hide all sections
      $('#sec-circular').hide();
      $('#sec-report').hide();
      $('[id^=sec-master-]').hide();

      // Show requested section
      $('#' + secId).show();

      // If it's a master data section, render table
      if (secId.startsWith('sec-master-')) {
        const type = secId.replace('sec-master-', '');
        renderMasterTable(type);
      }

      // If report section, populate dropdowns
      if (secId === 'sec-report') {
        populateReportDropdowns();
      }
    }

    // ============ MASTER DATA ============
    let masterTables = {};
    const masterConfig = {
      year: { dataKey: 'year', title: 'ปี พ.ศ.', pk: 'year_id', columns: ['year_value'], headers: ['ปี พ.ศ.'] },
      results: { dataKey: 'results', title: 'ผลการพิจารณา', pk: 'results_id', columns: ['results_detail'], headers: ['รายละเอียด'] },
      agency: { dataKey: 'agency', title: 'ผู้รับผิดชอบ', pk: 'ag_id', columns: ['ag_name'], headers: ['ชื่อผู้รับผิดชอบ'] },
      categories: { dataKey: 'categories', title: 'หมวดหมู่', pk: 'cat_id', columns: ['cat_name'], headers: ['ชื่อหมวดหมู่'] },
      mkk: { dataKey: 'mati_kk', title: 'มติ ก.ก.', pk: 'mkk_id', columns: ['mkk_name', 'mkk_date'], headers: ['ชื่อมติ', 'วันที่'] },
      mw: { dataKey: 'mati_work', title: 'มติคณะทำงาน', pk: 'mw_id', columns: ['mw_name', 'mw_date'], headers: ['ชื่อมติ', 'วันที่'] },
      status: { dataKey: 'status', title: 'สถานะการใช้งาน', pk: 'status_id', columns: ['status_value'], headers: ['สถานะ'] },
    };

    function renderMasterTable(type) {
      const conf = masterConfig[type];
      if (!conf) return;
      const dataArr = allData ? allData[conf.dataKey] : null;
      if (!dataArr) return;

      $('#master-title-' + type).text('ข้อมูลหลัก: ' + conf.title);

      // Render headers
      let theadHtml = '<tr><th>#</th>';
      conf.headers.forEach(h => { theadHtml += `<th>${h}</th>`; });
      theadHtml += '<th>จัดการ</th></tr>';
      $('#master-thead-' + type).html(theadHtml);

      // Render data
      if (masterTables[type]) {
        masterTables[type].destroy();
      }

      let tbodyHtml = '';
      dataArr.forEach((item, index) => {
        const pkValue = item[conf.pk];
        // assuming first column is the main text value for editing
        let rawVal = item[conf.columns[0]];
        if (rawVal === null || rawVal === undefined) rawVal = '';
        const mainVal = rawVal.toString().replace(/'/g, "\\'");
        tbodyHtml += `<tr><td>${index + 1}</td>`;
        conf.columns.forEach(col => {
          let val = item[col];
          if (val === '2222-01-01') val = '-';
          else if (val && typeof val === 'string' && val.match(/^\d{4}-\d{2}-\d{2}/)) {
            val = moment(val).add(543, 'year').format('LL');
          }
          tbodyHtml += `<td>${val || '-'}</td>`;
        });
        tbodyHtml += `<td>
          <button class="btn btn-sm btn-warning" onclick="openMasterModal('${type}', '${pkValue}', '${mainVal}')"><i class="bx bx-edit"></i></button>
          <button class="btn btn-sm btn-danger" onclick="deleteMasterData('${type}', '${pkValue}')"><i class="bx bx-trash"></i></button>
        </td></tr>`;
      });
      $('#master-tbody-' + type).html(tbodyHtml);

      masterTables[type] = $('#table-master-' + type).DataTable({
        responsive: true,
        language: {
          search: 'ค้นหา:', lengthMenu: 'แสดง _MENU_ รายการ', info: 'แสดง _START_ ถึง _END_ จากทั้งหมด _TOTAL_ รายการ',
          infoEmpty: 'ไม่มีข้อมูล', zeroRecords: 'ไม่พบข้อมูล', paginate: { first: 'แรก', last: 'สุดท้าย', next: 'ถัดไป', previous: 'ก่อนหน้า' }
        }
      });
    }

    function openMasterModal(type, id = null, currentVal = '') {
      const conf = masterConfig[type];
      Swal.fire({
        title: id ? `แก้ไขข้อมูล: ${conf.title}` : `เพิ่มข้อมูล: ${conf.title}`,
        input: 'text',
        inputValue: currentVal,
        inputPlaceholder: 'กรอกข้อมูล...',
        showCancelButton: true,
        confirmButtonText: 'บันทึก',
        cancelButtonText: 'ยกเลิก',
        inputValidator: (value) => {
          if (!value) return 'กรุณากรอกข้อมูล!';
        }
      }).then((result) => {
        if (result.isConfirmed) {
          const action = id ? 'update' : 'create';
          $.post('/admincscit/service/master/action', { action, type, id, value: result.value })
            .done(function (r) {
              if (r.status) {
                Swal.fire({ icon: 'success', title: 'สำเร็จ', text: r.message, timer: 1500, showConfirmButton: false });
                loadData(); // reload data
                setTimeout(() => showSection('sec-master-' + type), 500); // return to section
              } else {
                Swal.fire('ผิดพลาด', r.message, 'error');
              }
            }).fail(function (xhr) {
              Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error');
            });
        }
      });
    }

    function deleteMasterData(type, id) {
      Swal.fire({
        title: 'ยืนยันการลบ?',
        text: "ข้อมูลนี้จะถูกลบออกจากระบบ!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'ใช่, ลบเลย!',
        cancelButtonText: 'ยกเลิก'
      }).then((result) => {
        if (result.isConfirmed) {
          $.post('/admincscit/service/master/action', { action: 'delete', type, id })
            .done(function (r) {
              if (r.status) {
                Swal.fire({ icon: 'success', title: 'ลบสำเร็จ', text: r.message, timer: 1500, showConfirmButton: false });
                loadData();
                setTimeout(() => showSection('sec-master-' + type), 500);
              } else {
                Swal.fire('ผิดพลาด', r.message, 'error');
              }
            }).fail(function (xhr) {
              Swal.fire('ผิดพลาด', xhr.responseJSON?.message || 'เกิดข้อผิดพลาด', 'error');
            });
        }
      });
    }


    // ============ REPORT ============
    function populateReportDropdowns() {
      if (!allData) return;
      $('#rpt-year').html('<option value="">ทั้งหมด</option>');
      if (allData.year) allData.year.forEach(y => $('#rpt-year').append(`<option value="${y.year_id}">${y.year_value}</option>`));

      $('#rpt-results').html('<option value="">ทั้งหมด</option>');
      if (allData.results) allData.results.forEach(r => $('#rpt-results').append(`<option value="${r.results_id}">${r.results_detail}</option>`));

      $('#rpt-agency').html('<option value="">ทั้งหมด</option>');
      if (allData.agency) allData.agency.forEach(a => $('#rpt-agency').append(`<option value="${a.ag_id}">${a.ag_name}</option>`));
    }

    let reportTable = null;
    function loadReport() {
      const year = $('#rpt-year').val();
      const res = $('#rpt-results').val();
      const ag = $('#rpt-agency').val();

      let filtered = allData.information.filter(item => {
        let matchYear = true;
        if (year && item.year) {
          matchYear = item.year.year_id == year;
        } else if (year) matchYear = false;

        let matchRes = true;
        if (res && item.results) {
          matchRes = item.results.results_id == res;
        } else if (res) matchRes = false;

        let matchAg = true;
        if (ag && item.agency) {
          matchAg = item.agency.some(a => a.ag_id == ag);
        } else if (ag) matchAg = false;

        return matchYear && matchRes && matchAg;
      });

      // Count stats
      let cntAll = filtered.length;
      let cntUse = filtered.filter(i => i.results && i.results.results_id == 2).length;
      let cntAdj = filtered.filter(i => i.results && i.results.results_id == 4).length;
      let cntNot = filtered.filter(i => i.results && i.results.results_id == 5).length;
      let cntPen = filtered.filter(i => i.results && i.results.results_id == 12).length;
      let cntMis = filtered.filter(i => i.results && i.results.results_id == 11).length;
      let cntNon = filtered.filter(i => i.results && i.results.results_id == 1).length;

      $('#rpt-cnt-all').text(cntAll);
      $('#rpt-cnt-use').text(cntUse);
      $('#rpt-cnt-adjust').text(cntAdj);
      $('#rpt-cnt-notuse').text(cntNot);
      // (Optionally add more summary cards to report UI if needed)
      $('#rpt-summary-row').show();

      // Render table
      if (reportTable) reportTable.destroy();

      let tbodyHtml = '';
      filtered.forEach((item, i) => {
        let agStr = item.agency ? item.agency.map(a => `<span class="badge bg-dark">${a.ag_name}</span>`).join(' ') : '-';
        let yearStr = item.year ? item.year.year_value : '-';
        let resStr = item.results ? item.results.results_detail : '-';
        let statusStr = item.status_a ? item.status_a.status_value : '-';
        let resColor = item.results ? item.results.results_color : '000';

        let statusBadge = statusStr === 'ใช้งาน' ? 'bg-success' : (statusStr === 'ยกเลิก' ? 'bg-danger' : 'bg-secondary');

        tbodyHtml += `<tr>
          <td class="text-center">${i + 1}</td>
          <td class="text-center">${yearStr}</td>
          <td>${item.in_num_date}</td>
          <td>${item.in_detail}</td>
          <td class="text-center"><span style="color:#${resColor};font-weight:600;">${resStr}</span></td>
          <td>${agStr}</td>
          <td class="text-center"><span class="badge ${statusBadge}">${statusStr}</span></td>
        </tr>`;
      });
      $('#rpt-tbody').html(tbodyHtml);
      $('#table-report').show();

      reportTable = $('#table-report').DataTable({
        responsive: true,
        language: {
          search: 'ค้นหาในตาราง:', lengthMenu: 'แสดง _MENU_ รายการ', info: 'แสดง _START_ ถึง _END_ จากทั้งหมด _TOTAL_ รายการ',
          infoEmpty: 'ไม่มีข้อมูล', zeroRecords: 'ไม่พบข้อมูล', paginate: { first: 'แรก', last: 'สุดท้าย', next: 'ถัดไป', previous: 'ก่อนหน้า' }
        }
      });
    }

    $(document).ready(function () {
      loadData();

      // Fallback: Ensure menu toggles work if Sneat menu.js fails to bind
      $('.menu-toggle').off('click').on('click', function (e) {
        e.preventDefault();
        const $item = $(this).closest('.menu-item');
        if ($item.hasClass('open')) {
          $item.removeClass('open');
          $(this).siblings('.menu-sub').slideUp(200);
        } else {
          // close others if needed
          $item.siblings('.open').removeClass('open').find('.menu-sub').slideUp(200);
          $item.addClass('open');
          $(this).siblings('.menu-sub').slideDown(200);
        }
      });
    });
  </script>
</body>

</html>