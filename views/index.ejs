      <script>
        // โหลด stats การ์ด
        (function loadPublicStats() {
          $.get('/service/api/stats.php')
            .done(function(r) {
              if (!r.status) return;
              var d = r.response;
              function animateCount(el, target) {
                var start = 0, duration = 800, step = Math.ceil(target / 40);
                var timer = setInterval(function() {
                  start += step;
                  if (start >= target) { start = target; clearInterval(timer); }
                  $(el).text(start.toLocaleString());
                }, duration / 40);
              }
              animateCount('#pub-count-all',    d.count_all    || 0);
              animateCount('#pub-count-use',    d.count_use    || 0);
              animateCount('#pub-count-adjust', d.count_adjust || 0);
              animateCount('#pub-count-notuse', d.count_notuse || 0);
              animateCount('#pub-count-pending', d.count_pending || 0);
              animateCount('#pub-count-missing', d.count_missing || 0);
              // แสดง section
              $('#stats-row-public').addClass('stats-loaded');
            })
            .fail(function() {
              $('#stats-row-public').hide();
            });
        })();
      </script>
