        /* ====== STATS CARDS ====== */
        .stats-card {
          border: none;
          border-radius: 14px;
          box-shadow: 0 2px 12px rgba(0,0,0,.07);
          transition: transform .2s, box-shadow .2s;
        }
        .stats-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 6px 20px rgba(0,0,0,.12);
        }
        .stats-icon-wrap {
          width: 52px;
          height: 52px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          flex-shrink: 0;
        }
        .stats-icon { font-size: 1.6rem; }
        .bg-soft-blue   { background: #dbeafe; }
        .bg-soft-green  { background: #dcfce7; }
        .bg-soft-yellow { background: #fef9c3; }
        .bg-soft-red    { background: #fee2e2; }
        .bg-soft-orange { background: #ffedd5; }
        .bg-soft-purple { background: #f3e8ff; }
        .stats-label {
          font-size: .78rem;
          color: #6c757d;
          font-weight: 600;
          white-space: nowrap;
        }
        .stats-number {
          font-size: 1.7rem;
          font-weight: 800;
          line-height: 1.1;
        }
        .stats-unit {
          font-size: .72rem;
          color: #9ca3af;
        }
        #stats-row-public {
          opacity: 0;
          transform: translateY(12px);
          transition: opacity .5s, transform .5s;
        }
        #stats-row-public.stats-loaded {
          opacity: 1;
          transform: none;
        }
        /* ====== END STATS CARDS ====== */

        /* ====== CHATBOT BUTTON ====== */
        .chatbot-btn {
          position: fixed;
          bottom: 100px; /* วางเหนือปุ่ม scroll to top */
          right: 30px;
          width: 65px;
          height: 65px;
          background: linear-gradient(135deg, #20c997, #0dcaf0);
          color: white;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 32px;
          box-shadow: 0 4px 15px rgba(32, 201, 151, 0.4);
          z-index: 9999;
          transition: transform 0.3s ease, box-shadow 0.3s ease;
          text-decoration: none;
          animation: pulse-glow 2s infinite;
        }
        .chatbot-btn:hover {
          transform: translateY(-5px) scale(1.05);
          box-shadow: 0 8px 25px rgba(32, 201, 151, 0.5);
          color: white;
        }
        @keyframes pulse-glow {
